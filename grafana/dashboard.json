    {
      "id": 1,
      "title": "Analog Channel 1 (Voltage)",
      "type": "gauge",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-smartfactory"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT analog_ch1 AS \"value\" FROM telemetry_data ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 5,
          "unit": "volt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3.5 },
              { "color": "red", "value": 4.5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
